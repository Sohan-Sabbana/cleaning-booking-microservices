    },
    {
      "name": "PROFESSIONALS-SERVICE (via Gateway)",
      "item": [
        {
          "name": "List Vehicles (sets vehicleId/cleanerId)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/professionals/vehicles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "professionals",
                "vehicles"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });",
                  "const data = pm.response.json();",
                  "if (Array.isArray(data) && data.length > 0) {",
                  "  pm.collectionVariables.set(\"vehicleId\", data[0].id);",
                  "  if (data[0].cleaners && data[0].cleaners.length > 0) {",
                  "    pm.collectionVariables.set(\"cleanerId\", data[0].cleaners[0].id);",
                  "  }",
                  "}",
                  ""
                ]
              }
            }
          ]
        },
        {
          "name": "List All Cleaners",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/professionals/cleaners",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "professionals",
                "cleaners"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "List Cleaners by Vehicle (uses {{vehicleId}})",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/professionals/vehicles/{{vehicleId}}/cleaners",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "professionals",
                "vehicles",
                "{{vehicleId}}",
                "cleaners"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "BOOKING-SERVICE (via Gateway)",
      "item": [
        {
          "name": "Availability by Date (date={{date}})",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/availability?date={{date}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "availability"
              ],
              "query": [
                {
                  "key": "date",
                  "value": "{{date}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Availability for Slot (startAt={{startAt}}, durationHours={{durationHours}}, professionalCount={{professionalCount}})",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/availability/slot?startAt={{startAt}}&durationHours={{durationHours}}&professionalCount={{professionalCount}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "availability",
                "slot"
              ],
              "query": [
                {
                  "key": "startAt",
                  "value": "{{startAt}}"
                },
                {
                  "key": "durationHours",
                  "value": "{{durationHours}}"
                },
                {
                  "key": "professionalCount",
                  "value": "{{professionalCount}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Booking (sets bookingId + vehicleId)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/bookings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "bookings"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"startAt\": \"{{startAt}}\",\n  \"durationHours\": 2,\n  \"professionalCount\": 2\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });",
                  "const b = pm.response.json();",
                  "if (b && b.id) pm.collectionVariables.set(\"bookingId\", b.id);",
                  "if (b && b.vehicleId) pm.collectionVariables.set(\"vehicleId\", b.vehicleId);",
                  ""
                ]
              }
            }
          ]
        },
        {
          "name": "Update Booking (uses {{bookingId}})",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/bookings/{{bookingId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "bookings",
                "{{bookingId}}"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newStartAt\": \"{{newStartAt}}\",\n  \"newDurationHours\": 2\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
