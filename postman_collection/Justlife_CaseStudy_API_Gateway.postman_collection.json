  "item": [
    {
      "name": "OpenAPI Docs (via Gateway)",
      "item": [
        {
          "name": "Professionals OpenAPI JSON",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/professionals/v3/api-docs",
